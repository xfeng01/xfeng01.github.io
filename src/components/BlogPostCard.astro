---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const tags = post.data.tags ?? [];

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
---

<article class="grid gap-2.5 py-5 sm:grid-cols-[8.5rem_minmax(0,1fr)] sm:gap-6">
  <p class="mb-0 pt-0.5 text-sm leading-6 text-gray-500">{formatDate(post.data.date)}</p>
  <div class="min-w-0">
    <h3 class="mb-1.5 text-[1.26rem] font-semibold leading-snug text-gray-900">
      <a href={`/blog/${post.slug}/`} class="post-title-link">
        {post.data.title}
      </a>
    </h3>
    {
      tags.length > 0 && (
        <p class="mb-2 text-[0.72rem] font-semibold uppercase tracking-[0.11em] text-gray-400">
          {tags.join(' / ')}
        </p>
      )
    }
    <p class="mb-0 max-w-3xl text-[0.96rem] leading-6 text-gray-600">{post.data.description}</p>
  </div>
</article>

<style>
  .post-title-link {
    color: #111827;
    text-decoration: none;
    transition: color 150ms ease;
  }

  .post-title-link:hover {
    color: #4b5563;
    text-decoration: none;
  }
</style>
