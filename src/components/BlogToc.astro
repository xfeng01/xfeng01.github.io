---
interface TocItem {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  items: TocItem[];
}

const { items } = Astro.props;
---

{
  items.length > 0 && (
    <aside class="hidden xl:block xl:fixed xl:right-6 xl:top-32 xl:w-56 2xl:right-8 2xl:w-60">
      <div class="max-h-[calc(100vh-10rem)] overflow-y-auto border-l border-gray-200 pl-3">
        <p class="mb-2 text-[10px] font-semibold uppercase tracking-[0.2em] text-gray-400">On this page</p>
        <nav aria-label="Table of contents">
          <ul class="toc-list">
            {items.map((heading) => (
              <li class={heading.depth === 3 ? "toc-item toc-item-depth-3" : "toc-item"}>
                <a
                  href={`#${heading.slug}`}
                  class={heading.depth === 3 ? "toc-link toc-link-depth-3" : "toc-link"}
                  title={heading.text}
                >
                  <span
                    style="-webkit-line-clamp: 2; -webkit-box-orient: vertical; display: -webkit-box; overflow: hidden;"
                  >
                    {heading.text}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </aside>
  )
}

<style>
  .toc-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .toc-item {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .toc-item-depth-3 {
    padding-left: 0.875rem;
  }

  .toc-link {
    color: #4b5563;
    display: block;
    font-size: 0.86rem;
    font-weight: 500;
    line-height: 1.45;
    overflow: hidden;
    text-decoration: none;
    transition: color 150ms ease;
  }

  .toc-link-depth-3 {
    color: #6b7280;
    font-size: 0.78rem;
    font-weight: 400;
  }

  .toc-link:hover {
    color: #111827;
  }
</style>
