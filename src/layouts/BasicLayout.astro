---
import "../styles/global.css";
const { title = "Xinsong Feng", showProfile = true, compact = false } = Astro.props;
const pathname = Astro.url.pathname;
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/blog", label: "Blog" },
];
const mainClass = compact
  ? "max-w-7xl mx-auto py-8 min-h-screen"
  : "max-w-7xl mx-auto py-12 min-h-screen";
const headerClass = compact
  ? "mb-6 flex flex-col gap-3 border-b border-gray-200 pb-4 md:flex-row md:items-end md:justify-between"
  : "mb-8 flex flex-col gap-4 border-b border-gray-200 pb-6 md:flex-row md:items-end md:justify-between";
const navClass = compact
  ? "flex flex-wrap gap-2 text-xs font-semibold uppercase tracking-[0.18em]"
  : "flex flex-wrap gap-2 text-xs font-semibold uppercase tracking-[0.2em]";
const navLinkClass = compact
  ? "rounded-full border px-3 py-1.5 no-underline transition-colors"
  : "rounded-full border px-4 py-2 no-underline transition-colors";
const contentClass = compact ? "mt-5" : "mt-8";

export const info = {
  social: [
    {
      icon: "fas fa-envelope",
      color: "text-gray-600",
      name: "Email",
      link: "mailto:xsfeng@ucla.edu",
    },
    {
      icon: "fas fa-graduation-cap",
      color: "text-gray-600",
      name: "Google Scholar",
      link: "https://scholar.google.com/citations?hl=en&user=664D7CoAAAAJ",
    },
    {
      icon: "fab fa-github",
      color: "text-gray-600",
      name: "GitHub",
      link: "https://github.com/xfeng01",
    },
    {
      icon: "fas fa-file-contract",
      color: "text-gray-600",
      name: "Resume",
      link: "/CV.pdf",
    },
  ],
};
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body class="bg-white leading-relaxed text-gray-900">
    <main class={mainClass}>
      <div class={headerClass}>
        <h1 class="mb-0">
          <a href="/" class="no-underline" style="color: #111827;">
            Xinsong Feng (<span style="font-family: 'KaiTi', 'STKaiti', 'Kaiti SC', serif;">冯欣淞</span>)
          </a>
        </h1>
        <nav class={navClass}>
          {
            navLinks.map((link) => {
              const isActive =
                pathname === link.href ||
                (link.href !== "/" && pathname.startsWith(`${link.href}/`));

              return (
                <a
                  href={link.href}
                  class={navLinkClass}
                  style={isActive
                    ? "color: #111827; border-color: #d1d5db; background-color: #f3f4f6;"
                    : "color: #6b7280; border-color: #e5e7eb;"}
                >
                  {link.label}
                </a>
              );
            })
          }
        </nav>
      </div>
      <div class={contentClass}>
        {showProfile && (
          <div class="float-none md:float-right ml-0 md:ml-8 mb-4 w-full md:w-1/4">
            <img src="/xsfeng.jpg" alt="Xinsong Feng" class="rounded-lg shadow-md w-full">
            <div class="mt-4">
              <h2 class="font-bold text-lg text-gray-800 mb-2">LINKS</h2>
              <div class="flex space-x-2">
                {
                  info.social.map((social) => (
                  <a 
                    href={social.link} 
                    class="social-icon-link flex items-center justify-center w-12 h-12 rounded-full hover:bg-gray-100 no-underline"
                    title={social.name}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <i class={`${social.icon} ${social.color} text-3xl`} />
                  </a>
                  ))
                }
              </div>
            </div>
          </div>
        )}
        
        <slot />
      </div>
    </main>

    <footer class="max-w-7xl mx-auto py-6 text-center text-sm text-gray-500 border-t">
      © {new Date().getFullYear()} Xinsong Feng
    </footer>
	
  </body>
</html>
