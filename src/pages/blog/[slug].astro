---
import BasicLayout from '../../layouts/BasicLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import BlogToc from '../../components/BlogToc.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
const renderedTocHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);

const cleanTocText = (text: string) =>
  text
    .replace(/\$([^$]+)\$/g, (_, expression) => String(expression).replace(/\\/g, '').trim())
    .replace(/[*_`]/g, '')
    .replace(/\s+/g, ' ')
    .trim();

const markdownHeadingPattern = /^(#{2,3})\s+(.*)$/gm;
const rawTocItems = Array.from(post.body.matchAll(markdownHeadingPattern), (match) => ({
  depth: match[1].length,
  text: cleanTocText(match[2]),
}));

const tocItems = rawTocItems
  .map((item, index) => ({
    ...item,
    slug: renderedTocHeadings[index]?.slug ?? '',
  }))
  .filter((item) => item.slug);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
---

<BasicLayout title={`${post.data.title} | Xinsong Feng`} showProfile={false}>
  <article class="min-w-0 max-w-3xl">
    <header class="mb-10 border-b border-gray-200 pb-6">
      <p class="mb-4 text-sm font-medium text-gray-400">
        <a href="/blog" class="no-underline transition-colors hover:text-gray-900" style="color: #9ca3af;">
          Blog
        </a>
        <span class="mx-2">/</span>
        <span>{formatDate(post.data.date)}</span>
      </p>
      <h2 class="mb-3 text-4xl font-semibold leading-tight text-gray-900">{post.data.title}</h2>
      <p class="mb-0 max-w-2xl text-lg leading-8 text-gray-600">{post.data.description}</p>
      {
        post.data.tags && post.data.tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium uppercase tracking-[0.14em] text-gray-600">
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </header>

    <div class="text-gray-800">
      <Content />
    </div>
  </article>

  <BlogToc items={tocItems} />
</BasicLayout>
