---
import BasicLayout from '../../layouts/BasicLayout.astro';
import { getCollection } from 'astro:content';
import BlogPostCard from '../../components/BlogPostCard.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort((a, b) => {
  return b.data.date.getTime() - a.data.date.getTime();
});
---

<BasicLayout title="Blog | Xinsong Feng" showProfile={false}>
  <section class="max-w-4xl">
    <div class="border-b border-gray-200 pb-4">
      <div>
        <h2 class="mb-1 text-2xl font-semibold text-gray-900">Blog</h2>
        <p class="mb-0 max-w-2xl text-sm leading-6 text-gray-600">
          Research notes, paper summaries, and implementation details.
        </p>
      </div>
    </div>

    {
      posts.length === 0 ? (
        <div class="border-b border-dashed border-gray-300 py-6 text-gray-600">
          No posts yet.
        </div>
      ) : (
        <div>
          {posts.map((post) => <BlogPostCard post={post} />)}
        </div>
      )
    }
  </section>
</BasicLayout>
