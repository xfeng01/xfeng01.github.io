---
import BasicLayout from '../layouts/BasicLayout.astro';
import DisplayMath from '../components/DisplayMath.astro';
import { getEntry } from 'astro:content';

const project = await getEntry('projects', 'gtp');

if (!project) {
  throw new Error('Missing GTP project content.');
}

const { Content } = await project.render();
const { title, authors, pub, image, paper, code } = project.data;
const yourName = 'Xinsong Feng';
const citationAuthors = 'Feng, Xinsong and Tang, Leshu and Wang, Chenan and Chen, Haipeng';

const highlights = [
  {
    value: '89.0',
    label: 'D4RL Gym average',
    detail: 'Best average among the main offline RL baselines in the paper.',
  },
  {
    value: '80.6',
    label: 'D4RL AntMaze average',
    detail: 'Large gain on sparse-reward, long-horizon navigation tasks.',
  },
  {
    value: '100',
    label: 'AntMaze U-Maze',
    detail: 'Perfect normalized score in the full policy-improvement setting.',
  },
  {
    value: '0.67 ms',
    label: '2-step inference',
    detail: 'Short-horizon GTP keeps strong returns with lower latency.',
  },
];

const contributions = [
  'A unified ODE view that connects diffusion, flow matching, consistency models, and consistency trajectory models as trajectory-learning policies.',
  'Generative Trajectory Policies, which learn the ODE solution map directly instead of choosing between slow iterative sampling and brittle one-step shortcuts.',
  'Two offline RL adaptations: stable score approximation for efficient supervision, and advantage-weighted generative training for value-guided policy improvement.',
];

const methodDetails = [
  {
    step: 'Core 1',
    title: 'Learn a trajectory-level policy',
    text: String.raw`$$
\Phi(x_t,t,s)=x_t+\int_t^s f(x_\tau,\tau)\,d\tau=x_s
$$
$$
\Phi_\theta(x_t,t,s)\approx \Phi(x_t,t,s)
$$`,
    body: 'GTP learns the ODE solution map itself. This lets the policy preserve trajectory information while still generating actions with only a few learned jumps.',
  },
  {
    step: 'Core 2',
    title: 'Use score approximation for stable supervision',
    text: String.raw`$$
a_t=a+t z,\qquad
\tilde f(a_t,t)=\frac{a_t-a}{t}
$$`,
    body: 'Training a full trajectory map from scratch can become self-referential and expensive. GTP avoids repeated inner-loop ODE solves by anchoring the training signal to offline data through a closed-form score surrogate.',
  },
  {
    step: 'Core 3',
    title: 'Turn imitation into value-guided improvement',
    text: String.raw`$$
w(s,a)=\exp\left(\eta\frac{\max(0,A(s,a))}{\operatorname{std}(A)+\epsilon}\right)
$$`,
    body: 'The actor still learns from dataset actions, but high-advantage actions receive larger generative weights. This keeps policy improvement data-supported instead of relying on unstable unconstrained Q maximization.',
  },
];

const methodFigures = [
  {
    title: 'Stable score approximation',
    image: '/gtp/stable-score-approximation.webp',
    alt: 'Stable score approximation diagram for GTP training',
    caption: 'A data-anchored approximate score provides stable trajectory supervision without repeatedly solving the ODE.',
  },
  {
    title: 'Value-driven guidance',
    image: '/gtp/value-driven-guidance.webp',
    alt: 'Value-driven guidance diagram for GTP policy improvement',
    caption: 'Advantage weighting shifts the learned trajectory toward higher-value actions while staying aligned with data.',
  },
];

const bcRows = [
  {
    suite: 'Gym',
    ours: '82.3',
    comparison: [
      { name: 'D-BC', score: '76.3' },
      { name: 'C-BC', score: '69.7' },
    ],
    note: 'Best average behavior-cloning policy across the locomotion suite.',
  },
  {
    suite: 'AntMaze',
    ours: '66.3',
    comparison: [
      { name: 'D-BC', score: '41.2' },
      { name: 'C-BC', score: '44.1' },
    ],
    note: 'Much stronger imitation on multimodal, long-horizon datasets.',
  },
];

const rlRows = [
  {
    suite: 'Gym',
    ours: '89.0',
    comparison: [
      { name: 'D-QL', score: '87.9' },
      { name: 'BDM', score: '87.3' },
      { name: 'QGPO', score: '86.6' },
    ],
    note: 'Highest average return in the main D4RL offline RL comparison.',
  },
  {
    suite: 'AntMaze',
    ours: '80.6',
    comparison: [
      { name: 'QGPO', score: '78.3' },
      { name: 'IDQL-A', score: '79.1' },
      { name: 'D-QL', score: '69.6' },
    ],
    note: 'Best average on the sparse-reward AntMaze suite.',
  },
];

const visualResults = [
  {
    title: 'Original dataset',
    image: '/gtp/multi-goal-dataset.webp',
    alt: 'Original multi-goal dataset trajectories',
    description: 'The behavior data contains four clear modes toward the four goals.',
  },
  {
    title: 'Diffusion-QL',
    image: '/gtp/multi-goal-diffusion-ql.webp',
    alt: 'Diffusion-QL trajectories in the multi-goal environment',
    description: 'Diffusion-style sampling covers the modes, but trajectories are visibly noisy.',
  },
  {
    title: 'Consistency-AC',
    image: '/gtp/multi-goal-consistency-ac.webp',
    alt: 'Consistency-AC trajectories in the multi-goal environment',
    description: 'Fast consistency sampling can distort the multimodal structure.',
  },
  {
    title: 'GTP',
    image: '/gtp/multi-goal-gtp.webp',
    alt: 'GTP trajectories in the multi-goal environment',
    description: 'GTP preserves all four goal-reaching modes with compact trajectories.',
  },
];

const evidenceItems = [
  {
    title: 'Sampling steps',
    equation: String.raw`$$
K=2
$$`,
    body: 'The two-step variant achieves a Gym average of 88.7 versus 89.0 for the five-step variant, showing that GTP does not rely on long ODE rollouts.',
  },
  {
    title: 'Compute profile',
    equation: String.raw`$$
0.67\ \mathrm{ms}
$$`,
    body: 'The K = 2 variant reports 3.8 hours of training and 0.67 ms inference, compared with 7.1 hours and 1.16 ms for Diffusion-QL under the matched setup.',
  },
  {
    title: 'Beyond D4RL',
    body: 'Additional OGBench and visual-observation experiments show that the same policy formulation can extend beyond low-dimensional state inputs.',
  },
];
---

<BasicLayout title={`${title} | Xinsong Feng`} showProfile={false}>
  <article class="gtp-project-page mx-auto max-w-4xl">
    <a href="/" class="gtp-muted-link mb-8 inline-flex text-sm">
      Back to homepage
    </a>

    <header class="border-b border-gray-200 pb-7 text-center">
      <h2 class="mx-auto mb-4 max-w-3xl text-3xl font-semibold leading-tight text-gray-900 sm:text-4xl">
        {title}
      </h2>

      <p class="mx-auto mb-2 max-w-3xl text-base leading-7 text-gray-700">
        {authors.map((author: string, index: number) => (
          <span class={author === yourName ? 'font-semibold underline decoration-gray-400 underline-offset-2' : ''}>
            {author}{index < authors.length - 1 ? ', ' : ''}
          </span>
        ))}
      </p>

      <p class="mb-6 text-base text-gray-800">
        <span class="italic">{pub}</span>
      </p>

      <div class="flex flex-wrap items-center justify-center gap-2">
        {paper && (
          <a
            href={paper}
            target="_blank"
            rel="noopener noreferrer"
            class="gtp-button rounded border border-gray-300 px-4 py-2 text-sm font-semibold transition-colors hover:bg-gray-100"
          >
            Paper
          </a>
        )}
        {code && (
          <a
            href={code}
            target="_blank"
            rel="noopener noreferrer"
            class="gtp-button rounded border border-gray-300 px-4 py-2 text-sm font-semibold transition-colors hover:bg-gray-100"
          >
            Code
          </a>
        )}
      </div>

      <nav class="gtp-section-nav mt-7" aria-label="Project sections">
        <a href="#overview" class="gtp-section-link">Overview</a>
        <a href="#method" class="gtp-section-link">Method</a>
        <a href="#results" class="gtp-section-link">Results</a>
        <a href="#citation" class="gtp-section-link">Citation</a>
      </nav>
    </header>

    {image && (
      <figure class="my-8">
        <img
          src={image}
          alt="Generative Trajectory Policies overview"
          class="w-full rounded-md border border-gray-200 bg-white"
        />
        <figcaption class="mt-3 text-center text-sm leading-6 text-gray-600">
          GTP learns a direct flow map across a continuous-time generative trajectory, bridging the gap between expressive diffusion policies and efficient single-step policies.
        </figcaption>
      </figure>
    )}

    <section id="overview" class="border-t border-gray-200 pt-8">
      <div class="grid gap-5 md:grid-cols-[1.5fr_1fr]">
        <div>
          <h3 class="mb-4 text-2xl font-semibold text-gray-900">Overview</h3>
          <p class="text-base leading-7 text-gray-800">
            Offline RL needs policies that can model complex, multimodal behavior while staying fast enough for practical
            action generation. Existing generative policies tend to sit at opposite ends of this trade-off: diffusion policies
            are expressive but slow, while consistency-style policies are fast but can lose policy quality.
          </p>
          <p class="mb-0 text-base leading-7 text-gray-800">
            GTP resolves this by learning the full solution map of a continuous-time generative ODE. The result is a policy
            class that preserves trajectory information while enabling short, deterministic sampling paths at inference time.
          </p>
        </div>
        <div class="rounded-md border border-gray-200 bg-gray-50 p-4">
          <h4 class="mb-3 text-base font-semibold text-gray-900">Contributions</h4>
          <ul class="mb-0 list-disc space-y-2 pl-5 text-sm leading-6 text-gray-700">
            {contributions.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <section class="mt-10 border-t border-gray-200 pt-8">
      <h3 class="mb-4 text-2xl font-semibold text-gray-900">Highlights</h3>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {highlights.map((item) => (
          <div class="rounded-md border border-gray-200 p-4">
            <div class="text-2xl font-semibold leading-none text-gray-900">{item.value}</div>
            <div class="mt-2 text-sm font-semibold text-gray-800">{item.label}</div>
            <p class="mb-0 mt-2 text-sm leading-6 text-gray-600">{item.detail}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mt-10 border-t border-gray-200 pt-8">
      <h3 class="mb-4 text-2xl font-semibold text-gray-900">Abstract</h3>
      <div class="blog-content">
        <Content />
      </div>
    </section>

    <section id="method" class="mt-10 border-t border-gray-200 pt-8">
      <h3 class="mb-3 text-2xl font-semibold text-gray-900">Method</h3>
      <p class="mb-5 max-w-3xl text-sm leading-6 text-gray-600">
        GTP is built around three choices: learn the trajectory map directly, stabilize supervision with a data-anchored
        score approximation, and guide the generative objective with critic advantages.
      </p>
      <div class="space-y-4">
        {methodDetails.map((item) => (
          <div class="grid gap-4 rounded-md border border-gray-200 p-4 md:grid-cols-[7rem_1fr]">
            <div class="text-xs font-semibold uppercase tracking-[0.12em] text-gray-500">{item.step}</div>
            <div>
              <h4 class="mb-3 text-base font-semibold text-gray-900">{item.title}</h4>
              <DisplayMath text={item.text} class="overflow-x-auto rounded bg-gray-50 px-3 py-2 text-gray-900" />
              <p class="mb-0 mt-3 text-sm leading-6 text-gray-700">{item.body}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-5 grid gap-4 md:grid-cols-2">
        {methodFigures.map((item) => (
          <figure class="rounded-md border border-gray-200 bg-white p-3">
            <img
              src={item.image}
              alt={item.alt}
              loading="lazy"
              class="w-full rounded border border-gray-100 bg-white"
            />
            <figcaption class="mt-2">
              <div class="text-center text-sm font-semibold text-gray-800">{item.title}</div>
              <p class="mx-auto mb-0 mt-1 max-w-sm text-center text-xs leading-5 text-gray-600">{item.caption}</p>
            </figcaption>
          </figure>
        ))}
      </div>
    </section>

    <section id="results" class="mt-10 border-t border-gray-200 pt-8">
      <h3 class="mb-4 text-2xl font-semibold text-gray-900">Results</h3>
      <div class="overflow-x-auto rounded-md border border-gray-200">
        <table class="w-full min-w-[680px] border-collapse text-left text-sm">
          <thead class="bg-gray-50 text-gray-700">
            <tr>
              <th class="border-b border-gray-200 px-4 py-3 font-semibold">Setting</th>
              <th class="border-b border-gray-200 px-4 py-3 font-semibold">GTP</th>
              <th class="border-b border-gray-200 px-4 py-3 font-semibold">Other Models</th>
              <th class="border-b border-gray-200 px-4 py-3 font-semibold">Takeaway</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="border-b border-gray-100 px-4 py-3 font-semibold text-gray-900" colspan="4">Behavior cloning</td>
            </tr>
            {bcRows.map((row) => (
              <tr>
                <td class="border-b border-gray-100 px-4 py-3 text-gray-800">{row.suite}</td>
                <td class="border-b border-gray-100 px-4 py-3 font-semibold text-gray-900">{row.ours}</td>
                <td class="border-b border-gray-100 px-4 py-3 text-gray-700">
                  <div class="gtp-model-list">
                    {row.comparison.map((model) => (
                      <span class="gtp-model-token">
                        <span class="gtp-model-name">{model.name}</span>
                        <span class="gtp-model-score">{model.score}</span>
                      </span>
                    ))}
                  </div>
                </td>
                <td class="border-b border-gray-100 px-4 py-3 text-gray-700">{row.note}</td>
              </tr>
            ))}
            <tr>
              <td class="border-b border-gray-100 px-4 py-3 font-semibold text-gray-900" colspan="4">Policy improvement</td>
            </tr>
            {rlRows.map((row) => (
              <tr>
                <td class="border-b border-gray-100 px-4 py-3 text-gray-800">{row.suite}</td>
                <td class="border-b border-gray-100 px-4 py-3 font-semibold text-gray-900">{row.ours}</td>
                <td class="border-b border-gray-100 px-4 py-3 text-gray-700">
                  <div class="gtp-model-list">
                    {row.comparison.map((model) => (
                      <span class="gtp-model-token">
                        <span class="gtp-model-name">{model.name}</span>
                        <span class="gtp-model-score">{model.score}</span>
                      </span>
                    ))}
                  </div>
                </td>
                <td class="border-b border-gray-100 px-4 py-3 text-gray-700">{row.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mb-0 mt-3 text-sm leading-6 text-gray-600">
        Scores are normalized D4RL averages reported in the paper. Full per-task results, ablations, and additional baselines are in the PDF.
      </p>
    </section>

    <section class="mt-10 border-t border-gray-200 pt-8">
      <h3 class="mb-3 text-2xl font-semibold text-gray-900">Policy Visualization</h3>
      <p class="mb-5 max-w-3xl text-sm leading-6 text-gray-600">
        A 2D multi-goal environment gives a qualitative view of policy expressiveness. The target dataset is multimodal,
        and the learned policy should preserve all goal-reaching modes rather than collapsing to a single direction.
      </p>
      <div class="grid gap-4 md:grid-cols-2">
        {visualResults.map((item) => (
          <figure class="rounded-md border border-gray-200 bg-white p-3">
            <img
              src={item.image}
              alt={item.alt}
              loading="lazy"
              class="w-full rounded border border-gray-100 bg-white"
            />
            <figcaption class="mt-2 text-center">
              <div class="text-sm font-semibold text-gray-800">{item.title}</div>
              <p class="mx-auto mb-0 mt-1 max-w-sm text-xs leading-5 text-gray-600">{item.description}</p>
            </figcaption>
          </figure>
        ))}
      </div>
      <p class="mb-0 mt-4 rounded-md border border-gray-200 bg-gray-50 p-4 text-sm leading-6 text-gray-700">
        The key point is mode preservation: in this toy environment, a strong generative policy should not collapse to one
        goal or smear probability mass across the space. GTP keeps the four-way structure while avoiding long iterative
        diffusion sampling.
      </p>
    </section>

    <section class="mt-10 border-t border-gray-200 pt-8">
      <h3 class="mb-4 text-2xl font-semibold text-gray-900">Additional Evidence</h3>
      <div class="grid gap-4 md:grid-cols-3">
        {evidenceItems.map((item) => (
          <div class="rounded-md border border-gray-200 p-4">
            <h4 class="mb-2 text-base font-semibold text-gray-900">{item.title}</h4>
            {'equation' in item && item.equation && (
              <DisplayMath text={item.equation} class="mb-3 overflow-x-auto rounded bg-gray-50 px-3 py-2 text-gray-900" />
            )}
            <p class="mb-0 text-sm leading-6 text-gray-700">{item.body}</p>
          </div>
        ))}
      </div>
    </section>

    <section id="citation" class="mt-10 border-t border-gray-200 pt-8">
      <h3 class="mb-4 text-2xl font-semibold text-gray-900">Citation</h3>
      <pre class="mb-0"><code>{`@inproceedings{feng2026offline,
  title = {Offline Reinforcement Learning with Generative Trajectory Policies},
  author = {${citationAuthors}},
  booktitle = {International Conference on Machine Learning},
  year = {2026}
}`}</code></pre>
    </section>
  </article>
</BasicLayout>

<style>
  .gtp-project-page :global(a.gtp-muted-link) {
    color: #6b7280;
    text-decoration: none;
  }

  .gtp-project-page :global(a.gtp-muted-link:hover) {
    color: #111827;
    text-decoration: underline;
    text-underline-offset: 0.16em;
  }

  .gtp-project-page :global(a.gtp-button) {
    color: #111827;
    text-decoration: none;
  }

  .gtp-project-page :global(a.gtp-button:hover) {
    color: #111827;
    text-decoration: none;
  }

  .gtp-section-nav {
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0;
    border-top: 1px solid #e5e7eb;
    padding-top: 1rem;
  }

  .gtp-project-page :global(a.gtp-section-link) {
    color: #4b5563;
    display: inline-flex;
    align-items: center;
    min-height: 1.75rem;
    padding: 0 0.9rem;
    border-right: 1px solid #e5e7eb;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .gtp-project-page :global(a.gtp-section-link:last-child) {
    border-right: 0;
  }

  .gtp-project-page :global(a.gtp-section-link:hover) {
    color: #111827;
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .gtp-model-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .gtp-model-token {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
    white-space: nowrap;
    border: 1px solid #e5e7eb;
    border-radius: 0.35rem;
    background: #f9fafb;
    padding: 0.2rem 0.48rem;
    color: #374151;
  }

  .gtp-model-name {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #4b5563;
  }

  .gtp-model-score {
    font-size: 0.86rem;
    font-weight: 700;
    color: #111827;
  }
</style>
